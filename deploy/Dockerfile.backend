FROM golang:1.22-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-w -s" -o viyoga ./cmd/viyoga/

FROM alpine:3.19
RUN apk --no-cache add ca-certificates tzdata
WORKDIR /app
COPY --from=builder /app/viyoga .
COPY --from=builder /app/../../configs/viyoga.example.yaml ./viyoga.yaml

EXPOSE 8080
ENTRYPOINT ["./viyoga"]
